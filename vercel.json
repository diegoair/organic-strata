{
  "rewrites": [
    { "source": "/genesis/(.*)", "destination": "/genesis/$1" },
    { "source": "/strata/(.*)", "destination": "/strata/$1" },
    { "source": "/spore/(.*)", "destination": "/spore/$1" },
    { "source": "/pollen/(.*)", "destination": "/pollen/$1" },
    { "source": "/livingpath/(.*)", "destination": "/livingpath/$1" },
    { "source": "/", "destination": "/index.html" }
  ]
}
