{
  "version": 2,
  "name": "organic-strata",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "strata/**", "use": "@vercel/static" },
    { "src": "genesis/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "/genesis/(.*)", "dest": "/genesis/$1" },
    { "src": "/strata/(.*)", "dest": "/strata/$1" }
  ]
}
